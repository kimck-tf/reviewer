<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="utf-8">
<title>보고서 검토 결과: {{ title }}</title>
<link rel="stylesheet" href="assets/style.css">
</head>
<body>
<h1>보고서 검토 결과: {{ title }}</h1>
<div class="summary">
  <p>슬라이드 수: {{ slide_count }}</p>
  <p>총 이슈: {{ total_issues }}개</p>
  {% if total_issues > 0 and severity_counts %}
  <p>발견 건수:
    {% for sev_key, sev_label, count in severity_counts %}
      <span class="severity-{{ sev_key }}">{{ sev_label }}: {{ count }}</span>{% if not loop.last %} · {% endif %}
    {% endfor %}
  </p>
  {% endif %}
  <div class="severity-legend">
    <strong>심각도 척도</strong>:
    <span class="severity-critical">🔴 Critical</span>(반드시 수정) ·
    <span class="severity-warning">🟠 Warning</span>(수정 권장) ·
    <span class="severity-minor">🔵 Minor</span>(참고)
  </div>
</div>

{% if document_review %}
<section class="document-review">
  <h2>문서 전체 평가</h2>
  {% if document_review.overall_grade %}
  <div class="overall-grade grade-{{ document_review.overall_grade }}">
    <span class="grade-label">종합 등급</span>
    <span class="grade-value">{{ document_review.overall_grade_label }}</span>
  </div>
  {% endif %}
  {% if document_review.overall_assessment %}
  <blockquote class="overall-assessment">{{ document_review.overall_assessment }}</blockquote>
  {% endif %}

  {% if document_review.thesis_question or document_review.thesis_answered %}
  <div class="doc-axis thesis">
    <h3>핵심 질문 답변 여부</h3>
    {% if document_review.thesis_question %}<p><strong>핵심 질문</strong>: {{ document_review.thesis_question }}</p>{% endif %}
    {% if document_review.thesis_answered %}
    <p><strong>답변 여부</strong>: <span class="thesis-{{ document_review.thesis_answered }}">{{ document_review.thesis_answered_label }}</span></p>
    {% endif %}
    {% if document_review.thesis_answer_summary %}<p><strong>판단 근거</strong>: {{ document_review.thesis_answer_summary }}</p>{% endif %}
  </div>
  {% endif %}

  {% for axis in document_review.axes %}
  <div class="doc-axis axis-{{ axis.severity }}">
    <h3>{{ axis.label }}</h3>
    {% if axis.severity %}<p><strong>평가</strong>: <span class="severity-{{ axis.severity }}">{{ axis.severity_label }}</span></p>{% endif %}
    {% if axis.assessment %}<p>{{ axis.assessment }}</p>{% endif %}
  </div>
  {% endfor %}

  {% if document_review.cross_slide_concerns %}
  <div class="doc-axis cross-slide">
    <h3>슬라이드 간 모순·중복</h3>
    <ul>
    {% for c in document_review.cross_slide_concerns %}
      <li class="concern severity-{{ c.severity }}">
        <strong>{{ c.severity_label }}</strong>
        {% if c.slide_indexes_label %} · {{ c.slide_indexes_label }}{% endif %}
        {% if c.issue %}<div>문제: {{ c.issue }}</div>{% endif %}
        {% if c.suggestion %}<div>제안: {{ c.suggestion }}</div>{% endif %}
      </li>
    {% endfor %}
    </ul>
  </div>
  {% endif %}
</section>
{% endif %}

{% if total_issues == 0 %}
<div class="empty">
  <h2>검토 결과 이슈 없음</h2>
  <p>발견된 이슈가 없습니다.</p>
</div>
{% else %}
{% for slide in slides_with_findings %}
<div class="slide-card">
  <h3>슬라이드 {{ slide.index }}{% if slide.title %}: {{ slide.title }}{% endif %}</h3>
  {% if slide.thumbnail_rel %}
  <div class="slide-thumb-wrap">
    <img src="{{ slide.thumbnail_rel }}" alt="슬라이드 {{ slide.index }}">
    {% for box in slide.boxes %}
    <div class="position-box" style="left:{{ box.left }}%; top:{{ box.top }}%; width:{{ box.width }}%; height:{{ box.height }}%;"></div>
    {% endfor %}
  </div>
  {% endif %}
  {% for f in slide.findings %}
  <div class="finding-card {{ f.severity }}">
    <strong>[{{ f.id }}]{% if f.source_ids_suffix %} <span class="source-ids">{{ f.source_ids_suffix }}</span>{% endif %} {{ f.severity_label }} · {{ f.category_label }}</strong>
    <p>원문: "{{ f.quoted_text }}"</p>
    <p>문제: {{ f.issue }}</p>
    <p>개선 제안: {{ f.suggestion }}</p>
    {% if f.evidence %}<p>근거: {{ f.evidence }}</p>{% endif %}
  </div>
  {% endfor %}
</div>
{% endfor %}

{% if categories_with_findings %}
<section class="categories-section">
  <h2>카테고리별 이슈</h2>
  {% for cat in categories_with_findings %}
  <div class="category-group" data-category="{{ cat.key }}">
    <h3>{{ cat.label }} ({{ cat.count }}건)</h3>
    <ul>
      {% for item in cat.findings %}
      <li class="cat-item severity-{{ item.severity }}">
        <strong>[{{ item.id }}]{% if item.source_ids_suffix %} <span class="source-ids">{{ item.source_ids_suffix }}</span>{% endif %}</strong>
        <span class="severity-{{ item.severity }}">{{ item.severity_label }}</span>
        · 슬라이드 {{ item.slide_index }}
        · {{ item.issue }}
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endfor %}
</section>
{% endif %}
{% endif %}
</body>
</html>
